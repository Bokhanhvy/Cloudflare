# Copy this file to .env and fill in real values for local development
# (`npm run dev`). Get these from your Supabase project dashboard:
# Project Settings → API.
#
# VITE_-prefixed variables are also readable in the browser bundle — never
# put secrets (like the service role key) behind a VITE_ prefix.

# Public Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
VITE_SUPABASE_URL=

# Public "anon"/"publishable" key — safe to expose to the browser; access
# is still restricted by this project's Row Level Security (RLS) policies.
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional, only used by tooling that looks up the project by ID.
SUPABASE_PROJECT_ID=
VITE_SUPABASE_PROJECT_ID=

# SECRET — server-only, bypasses Row Level Security. Required for the admin
# user-management functions (list/delete users, set roles, reset passwords)
# in src/lib/admin.functions.ts. Get it from Project Settings → API →
# service_role key. NEVER prefix this with VITE_, never commit it, and in
# production set it as a Cloudflare Worker *secret* (not a plain var) —
# see DEPLOYMENT.md.
SUPABASE_SERVICE_ROLE_KEY=
